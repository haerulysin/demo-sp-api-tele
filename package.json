{
	"name": "amz-sp-api",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.30.3",
	"engines": {
		"node": ">=20",
		"pnpm": ">=9"
	},
	"scripts": {
		"preinstall": "node -e \"if (!(process.env.npm_config_user_agent || '').includes('pnpm')) { console.error('\\nThis project uses pnpm only. See https://pnpm.io/installation\\n'); process.exit(1); }\"",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"env:init": "node ./scripts/env-init.mjs",
		"env:init:local": "node ./scripts/env-init.mjs local",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"axios": "1.14.0"
	}
}
