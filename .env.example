# Project root (next to package.json). Vite load order:
#   .env, .env.local, .env.[mode], .env.[mode].local — later files override earlier.
#
# For day-to-day / backtesting on your machine, prefer ONLY .env.local (gitignored):
#   pnpm env:init:local
#
# Or copy this file manually:
#   .env          — shared defaults (optional)
#   .env.local    — your secrets; overrides .env (recommended for backtesting)
#
# https://vitejs.dev/guide/env-and-mode.html#env-files

AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
